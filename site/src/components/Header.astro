---
import { siteConfig } from '../site.config';
import ThemeToggle from './ThemeToggle.vue';
---

<header class="sticky top-0 z-50 w-full border-b border-line/50 bg-surface/80 backdrop-blur-md">
  <nav
    aria-label="主导航"
    class="container-page flex min-w-0 items-center justify-between gap-6 py-3 sm:pb-8 sm:pt-12"
  >
    <div class="flex min-w-0 items-center gap-6">
      <a
        href="/"
        class="t-link flex min-h-11 shrink-0 items-center gap-1.5 no-underline"
        aria-label={`${siteConfig.title} 首页`}
      >
        <span class="text-base font-bold text-ink">11408</span>
        <span class="hidden text-base font-light text-faint sm:inline">Vault</span>
      </a>

      <ul class="m-0 flex min-w-0 list-none items-center gap-3 overflow-x-auto p-0 sm:gap-6 sm:overflow-visible">
        {
          siteConfig.nav.map((item) => (
            <li class="shrink-0">
              <a
                href={item.href}
                class="t-link inline-flex min-h-11 items-center gap-1 font-mono text-[13px] tabular-nums tracking-tight text-faint no-underline hover:text-ink"
              >
                <span>{item.label}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="flex shrink-0 items-center gap-1 sm:gap-2">
      <button
        type="button"
        aria-label="搜索"
        title="搜索"
        class="t-link inline-flex min-h-11 min-w-11 cursor-pointer items-center justify-center gap-1.5 border-none bg-transparent p-2 text-faint outline-none hover:text-ink"
        data-search-trigger
      >
        <i class="i-lucide-search size-4" aria-hidden="true"></i>
        <kbd class="hidden font-mono text-xs text-faint sm:inline">Ctrl K</kbd>
      </button>
      <ThemeToggle client:load />
    </div>
  </nav>
</header>

<script>
  function bindSearchTrigger() {
    const btn = document.querySelector<HTMLElement>('[data-search-trigger]');
    if (!btn || btn.dataset.bound === 'true') return;
    btn.dataset.bound = 'true';
    btn.addEventListener('click', () => {
      window.dispatchEvent(new Event('open-search'));
    });
  }

  document.addEventListener('astro:page-load', bindSearchTrigger);
  bindSearchTrigger();
</script>
