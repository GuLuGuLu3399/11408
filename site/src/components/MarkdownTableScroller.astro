<script>
  function enhanceMarkdownTables() {
    document.querySelectorAll<HTMLTableElement>('.prose-blog table').forEach((table) => {
      if (table.closest('.table-scroll')) return;

      const wrapper = document.createElement('div');
      wrapper.className = 'table-scroll';
      wrapper.tabIndex = 0;
      wrapper.setAttribute('role', 'region');
      wrapper.setAttribute('aria-label', '可横向滚动的表格');

      table.before(wrapper);
      wrapper.append(table);
    });
  }

  document.addEventListener('astro:page-load', enhanceMarkdownTables);
  enhanceMarkdownTables();
</script>

