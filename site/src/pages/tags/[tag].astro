---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { buildTagGroups, getNoteTitle, type TagGroup } from '../../lib/taxonomy';
import { notePath } from '../../lib/vault-notes';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  const groups = buildTagGroups(notes);

  return groups.map((group) => ({
    params: { tag: group.slug },
    props: { group },
  }));
}

type Props = {
  group: TagGroup;
};

const { group } = Astro.props;
---

<Layout title={`#${group.tag}`} description={`带有 #${group.tag} 标签的 11408 Vault 笔记。`}>
  <section aria-label={`#${group.tag} 标签`}>
    <p class="mb-2 font-mono text-[13px] tabular-nums tracking-tight text-faint">
      Tag
    </p>
    <h1 class="mb-12 text-2xl font-semibold tracking-tight text-ink sm:text-3xl">
      #{group.tag}
      <span class="ml-3 font-mono text-[13px] tabular-nums tracking-tight text-faint">
        {group.notes.length}
      </span>
    </h1>

    <ul class="m-0 list-none space-y-1 p-0">
      {
        group.notes.map((note) => (
          <li class="border-l-2 border-transparent px-3 py-2 hover:border-accent hover:bg-canvas/55">
            <a
              href={notePath(note.id)}
              class="t-link text-base font-normal text-ink no-underline hover:text-accent"
            >
              {getNoteTitle(note)}
            </a>
          </li>
        ))
      }
    </ul>

    <hr class="mt-12 border-0 border-t border-line/50" />
    <a
      href="/topics"
      class="t-link mt-6 inline-flex items-center gap-1.5 font-mono text-[13px] tabular-nums tracking-tight text-faint no-underline hover:text-ink"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="m12 19-7-7 7-7" />
        <path d="M19 12H5" />
      </svg>
      cd ..
    </a>
  </section>
</Layout>
