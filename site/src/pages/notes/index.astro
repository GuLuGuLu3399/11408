---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import Layout from '../../layouts/Layout.astro';
import { byRecentDesc, getNoteTitle, getPublicNotes, notePath } from '../../lib/vault-notes';

const posts = getPublicNotes(await getCollection('notes')).sort(byRecentDesc);
---

<Layout title="Notes Archive" description="11408 Vault 全量笔记索引。">
  <section aria-label="全量笔记索引">
    <p class="mb-2 font-mono text-[13px] tabular-nums tracking-tight text-faint">
      Archive
    </p>
    <h1 class="mb-12 text-2xl font-semibold tracking-tight text-ink sm:text-3xl">
      全部笔记
      <span class="ml-3 font-mono text-[13px] tabular-nums tracking-tight text-faint">
        {posts.length}
      </span>
    </h1>
    <ul class="m-0 list-none space-y-3 p-0">
      {
        posts.map((post) => {
          const date = post.data.updated_at ?? post.data.created_at ?? post.data.pubDate;
          return (
            <li>
              <a
                href={notePath(post.id)}
                class="group flex min-w-0 items-baseline gap-4 py-1 no-underline outline-none"
              >
                <span class="flex w-36 shrink-0 items-center gap-3 text-gray-500 transition-colors duration-150 group-hover:text-gray-400">
                  <i
                    class="i-lucide-file-text h-4 w-4 shrink-0 translate-y-0.5"
                    aria-hidden="true"
                  />
                  {date && (
                    <FormattedDate
                      date={date}
                      class="text-sm tracking-tight text-current"
                    />
                  )}
                </span>
                <span class="min-w-0 break-words text-base font-medium text-ink underline-offset-4 transition-colors duration-150 group-hover:underline group-hover:decoration-gray-600 dark:text-gray-300 dark:group-hover:text-white">
                  {getNoteTitle(post)}
                </span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </section>
</Layout>
