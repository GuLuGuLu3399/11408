---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import Layout from '../../layouts/Layout.astro';
import { byRecentDesc, getNoteTitle, getPublicNotes, notePath } from '../../lib/vault-notes';

const posts = getPublicNotes(await getCollection('notes')).sort(byRecentDesc);
---

<Layout title="Notes Archive" description="11408 Vault 全量笔记索引。">
  <section aria-label="全量笔记索引">
    <p class="mb-2 font-mono text-[13px] tabular-nums tracking-tight text-faint">
      Archive
    </p>
    <h1 class="mb-12 text-2xl font-semibold tracking-tight text-ink sm:text-3xl">
      全部笔记
      <span class="ml-3 font-mono text-[13px] tabular-nums tracking-tight text-faint">
        {posts.length}
      </span>
    </h1>
    <ul class="m-0 list-none space-y-1 p-0">
      {
        posts.map((post) => {
          const date = post.data.updated_at ?? post.data.created_at ?? post.data.pubDate;
          return (
            <li class="border-l-2 border-transparent px-3 py-2.5 hover:border-accent hover:bg-canvas/55">
              <a
                href={notePath(post.id)}
                class="group flex min-w-0 flex-col items-start gap-1 no-underline sm:flex-row sm:items-baseline sm:gap-6"
              >
                {date && <FormattedDate date={date} class="shrink-0 text-[13px] sm:w-28" />}
                <span class="t-link min-w-0 break-words text-base font-normal text-ink group-hover:text-accent">
                  {getNoteTitle(post)}
                </span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </section>
</Layout>
