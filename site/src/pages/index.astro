---
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../site.config';
import { byRecentDesc, getNoteTitle, getPublicNotes, notePath } from '../lib/vault-notes';

const allNotes = getPublicNotes(await getCollection('notes')).sort(byRecentDesc);
const recentPosts = allNotes.slice(0, 15);
---

<Layout title={siteConfig.title} description={siteConfig.description}>
  <section aria-label="最新笔记">
    <p class="mb-2 font-mono text-[13px] tabular-nums tracking-tight text-faint">
      Vault Notes · 2026
    </p>
    <h1 class="mb-12 text-2xl font-semibold tracking-tight text-ink sm:mb-16 sm:text-3xl">
      最新笔记
    </h1>
    <ul class="m-0 list-none space-y-4 p-0">
      {
        recentPosts.map((post) => {
          const date = post.data.updated_at ?? post.data.created_at ?? post.data.pubDate;
          return (
            <li>
              <a
                href={notePath(post.id)}
                class="group flex min-w-0 items-baseline gap-4 py-1 no-underline outline-none"
              >
                <span class="flex w-36 shrink-0 items-center gap-3 text-gray-500 transition-colors duration-150 group-hover:text-gray-400">
                  <i
                    class="i-lucide-file-text h-4 w-4 shrink-0 translate-y-0.5"
                    aria-hidden="true"
                  />
                  {date && (
                    <FormattedDate
                      date={date}
                      class="text-sm tracking-tight text-current"
                    />
                  )}
                </span>
                <h2 class="min-w-0 break-words text-base font-medium text-ink underline-offset-4 transition-colors duration-150 group-hover:underline group-hover:decoration-gray-600 dark:text-gray-300 dark:group-hover:text-white">
                  {getNoteTitle(post)}
                </h2>
              </a>
            </li>
          );
        })
      }
    </ul>

    <a
      href="/notes"
      class="t-link mt-10 inline-flex items-center gap-1.5 font-mono text-[13px] tabular-nums tracking-tight text-faint no-underline hover:text-ink"
    >
      View all notes ({allNotes.length})
      <i class="i-lucide-arrow-right size-3.5" aria-hidden="true"></i>
    </a>
  </section>
</Layout>
