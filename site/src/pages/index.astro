---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SectionRail from '../components/SectionRail.astro';
import NoteListRow from '../components/NoteListRow.astro';
import { siteConfig } from '../site.config';
import {
  byRecentDesc,
  getNoteKind,
  getNoteTitle,
  getPublicNotes,
  notePath,
  type NoteEntry,
} from '../lib/vault-notes';
import { buildKnowledgeMap, slugifyTaxonomy } from '../lib/taxonomy';

const all = getPublicNotes(await getCollection('notes')).sort(byRecentDesc);

// Section Rail 数据分流:复用 getNoteKind(基于 type 标记),不引入新数据源。
const recent = all.slice(0, 8);
const mistakes = all.filter((n) => getNoteKind(n) === '错题日记');
const weekly = all.filter((n) => getNoteKind(n) === '周报');
const domains = buildKnowledgeMap(all); // 紧凑型:domain 名 + 计数

// 安全日期回退:updated_at → created_at → pubDate → null。
const noteDate = (n: NoteEntry) =>
  n.data.updated_at ?? n.data.created_at ?? n.data.pubDate ?? null;

const mistakesTag = slugifyTaxonomy('错题日记');
const weeklyTag = slugifyTaxonomy('周报');
---

<Layout title={siteConfig.title} description={siteConfig.description}>
  <!-- 页面标题:克制的工程化 eyebrow + 描述性 H1,不做营销 hero(memo §05 红线)。 -->
  <header class="mb-16 sm:mb-24">
    <p class="font-mono text-[13px] tabular-nums tracking-tight text-faint">
      11408 Vault · 2026
    </p>
    <h1 class="mt-3 text-2xl font-semibold tracking-tight text-ink sm:text-3xl">
      计算机基础与考研复习 · 笔记库
    </h1>
  </header>

  <div class="flex flex-col gap-16 sm:gap-24">
    <SectionRail
      index="01"
      label="RECENT"
      href="/notes"
      hrefLabel="View all notes"
      count={all.length}
    >
      <ul class="m-0 list-none space-y-3 p-0">
        {
          recent.map((post) => (
            <li>
              <NoteListRow
                href={notePath(post.id)}
                title={getNoteTitle(post)}
                date={noteDate(post)}
              />
            </li>
          ))
        }
      </ul>
    </SectionRail>

    <SectionRail
      index="02"
      label="TOPICS"
      href="/topics"
      hrefLabel="Browse knowledge map"
    >
      <ul class="m-0 list-none space-y-3 p-0">
        {
          domains.map((d) => (
            <li>
              <a
                href={`/topics#${d.id}`}
                class="group flex min-w-0 items-baseline justify-between gap-4 py-1 no-underline outline-none"
              >
                <span class="min-w-0 break-words text-base font-medium text-ink underline-offset-4 decoration-line motion-safe:transition-colors duration-150 group-hover:underline">
                  {d.name}
                </span>
                <span class="shrink-0 font-mono text-[13px] tabular-nums tracking-tight text-faint">
                  {d.count}
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </SectionRail>

    {
      /* 03 / MISTAKES —— 仅当存在错题日记时陈列,避免空壳段。
         错题 icon 用 circle-x 与 RECENT 的 file-text 区分。 */
      mistakes.length > 0 && (
        <SectionRail
          index="03"
          label="MISTAKES"
          href={`/tags/${mistakesTag}`}
          hrefLabel="Review all mistakes"
          count={mistakes.length}
        >
          <ul class="m-0 list-none space-y-3 p-0">
            {mistakes.slice(0, 6).map((post) => (
              <li>
                <NoteListRow
                  href={notePath(post.id)}
                  title={getNoteTitle(post)}
                  date={noteDate(post)}
                  icon="i-lucide-circle-x"
                />
              </li>
            ))}
          </ul>
        </SectionRail>
      )
    }

    {
      /* 04 / WEEKLY —— 周报入口,icon 用 calendar-range。 */
      weekly.length > 0 && (
        <SectionRail
          index="04"
          label="WEEKLY"
          href={`/tags/${weeklyTag}`}
          hrefLabel="All weekly notes"
          count={weekly.length}
        >
          <ul class="m-0 list-none space-y-3 p-0">
            {weekly.slice(0, 6).map((post) => (
              <li>
                <NoteListRow
                  href={notePath(post.id)}
                  title={getNoteTitle(post)}
                  date={noteDate(post)}
                  icon="i-lucide-calendar-range"
                />
              </li>
            ))}
          </ul>
        </SectionRail>
      )
    }
  </div>
</Layout>
